# Copy to .env and fill in. NEVER commit .env.

# Hugging Face (Spaces deploy, model/dataset push)
HF_TOKEN=

# Modal — hosts ALL models (serving) + fine-tuning job
# Prefer `modal token set` over env vars.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# FALLBACK ONLY — we self-host Aya & FLUX on Modal. Fill these only if the Cohere/BFL
# awards turn out to require their hosted APIs.
COHERE_API_KEY=
BFL_API_KEY=

# Runtime toggles
TUTORDESK_OFFLINE=0          # 1 = Off-the-Grid mode (local models only, no cloud APIs)
TUTORDESK_VISION_MODEL=4.5   # 4.5 (8B, accurate) | 4.6 (1.3B, lightweight fallback)

# Off-the-Grid / llama.cpp (required when TUTORDESK_OFFLINE=1)
# Download from https://huggingface.co/Qwen/Qwen3-4B-GGUF (q4_k_m is the recommended quant)
QWEN_GGUF_PATH=              # /path/to/qwen3-4b-q4_k_m.gguf
GGUF_N_GPU_LAYERS=-1         # -1 = all layers on GPU, 0 = CPU-only

# HF username (for dataset/model pushes — defaults to naazimsnh02)
HF_USERNAME=naazimsnh02
